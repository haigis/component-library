{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "emitDeclarationOnly": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", ".storybook"]
}
